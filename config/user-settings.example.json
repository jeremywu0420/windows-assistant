  "ui": {
    "dismissedHints": []
  },
  "screenshots": {
    "path": "",
    "keywords": {},
    "organizer": {
      "organizeByDate": true,
      "categoryUnderDate": true,
      "renameConflicts": true,
      "skipAlreadyOrganized": true,
      "includeSubfolders": false,
      "includeHiddenFiles": false,
      "showFullPaths": false
    }
  },
  "rules": [
    {
      "id": "downloads-count",
      "type": "downloadsCount",
      "label": "Downloads 檔案數量",
      "enabled": true,
      "threshold": 50,
      "level": "warn"
    },
    {
      "id": "ram-usage",
      "type": "ramUsage",
      "label": "RAM 使用率",
      "enabled": true,
      "threshold": 80,
      "level": "warn"
    },
    {
      "id": "project-stale",
      "type": "projectStale",
      "label": "專案太久未 commit",
      "enabled": true,
      "threshold": 24,
      "level": "warn"
    },
    {
      "id": "disk-free",
      "type": "diskFree",
      "label": "磁碟可用空間過低",
      "enabled": true,
      "threshold": 20,
      "level": "danger"
    }
  ],
  "modes": [],
  "projects": [],
