  "cleanup": {
    "enabledCategories": [],
    "lastScanAt": ""
  },
  "healthGuard": {
    "enabled": true,
    "mode": "normal",
    "intervalMinutes": 5,
    "cooldownMinutes": 30,
    "cpuTempC": 85,
    "gpuTempC": 85,
    "ramPercent": 85,
    "diskFreeGb": 50,
    "diskFreePercent": 15
