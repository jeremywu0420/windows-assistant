{
  "name": "pc-life-assistant",
  "version": "1.1.0",
  "description": "PC Life Assistant - 專為學生與工程師設計的 Windows 桌面助理，整合工作模式啟動、檔案整理、系統健康監控與 Git / 備份提醒。",
  "author": "jeremywu0420",
  "license": "MIT",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,green \"vite --host 127.0.0.1\" \"wait-on tcp:127.0.0.1:5173 && cross-env NODE_ENV=development electron .\"",
    "dev:vite": "vite --host 127.0.0.1",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 && cross-env NODE_ENV=development electron .",
    "build": "vite build",
    "preview": "vite preview",
    "gen:icons": "node scripts/generate-icons.js",
    "package": "npm run gen:icons && npm run build && electron-builder",
    "package:dir": "npm run gen:icons && npm run build && electron-builder --dir"
  },
  "build": {
    "appId": "com.jeremywu0420.pclifeassistant",
    "productName": "PC Life Assistant",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "config/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "config",
        "to": "config"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "PC Life Assistant"
    }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.0.7",
    "wait-on": "^8.0.1"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
